# 认证服务环境变量（复制为 .env 或写入部署平台环境配置）
# 启动时加载方式示例: AUTH_PORT=3002 node server/index.js
# 或在项目根目录 .env 中配置后由 pm2/docker 等注入

# ---------- 服务端口 ----------
# AUTH_PORT=3002

# ---------- 邮件验证码（SMTP） ----------
# 配置后，邮箱验证码会真实发送；不配置则仅在接口响应中返回 devCode（仅开发用）
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=your-sender@example.com
SMTP_PASS=your-smtp-password
# SMTP_FROM=your-sender@example.com

# 常见邮箱 SMTP 示例：
# 网易 163: SMTP_HOST=smtp.163.com  SMTP_PORT=465  SMTP_USER=你的163邮箱  SMTP_PASS=授权码
# QQ 邮箱:  SMTP_HOST=smtp.qq.com   SMTP_PORT=465  SMTP_USER=你的qq邮箱   SMTP_PASS=授权码
# 企业微信: 使用企业邮箱 SMTP 或自建邮箱服务

# ---------- 短信验证码 ----------
# 方式一：使用 Webhook（推荐，可对接任意短信服务商）
# 本服务会向该 URL 发起 POST，body: { phone, countryCode, code, text }
# 你可在自己的后端或云函数里接收后调用阿里云/腾讯云/Twilio 等 API 发短信
SMS_WEBHOOK_URL=https://your-api.com/send-sms
# SMS_WEBHOOK_AUTH=Bearer your-secret

# 方式二：直接对接某一家短信商需在 server/index.js 中扩展 sendSms()，
# 并配置该服务商的 Key/Secret 等环境变量（见下方说明）

# 国内常用短信服务商配置示例（需在代码中接入对应 SDK 后使用）：
# 阿里云: 开通「短信服务」- 申请签名与模板 - 使用 AccessKey 调用 SendSms
# 腾讯云: 开通「短信」- 申请签名与正文模板 - 使用 SecretId/SecretKey 调用
# 其他: Twilio、华为云、七牛等均有 HTTP API，可统一用 SMS_WEBHOOK_URL 转发
